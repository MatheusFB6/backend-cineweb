generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ENTIDADES DE USUÁRIOS
model Profile {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  name     String

  profile   Profile @relation(fields: [profileId], references: [id])
  profileId String

  address Address?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Address {
  id      String @id @default(uuid())
  street  String
  number  Int
  city    String
  state   String
  zipCode String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ENTIDADES DO CINEMA
model Cinema {
  id          Int      @id @default(autoincrement()) // Usando Int ao invés de BigInt por simplicidade e compatibilidade com APIs do Nest
  nome        String
  endereco    String
  listaSalas  Sala[]
  listaFilmes Filme[]
  listaSessao Sessao[]
}

enum Genero {
  ACAO
  AVENTURA
  COMEDIA
  DRAMA
  TERROR
  FICCAO
  ROMANCE
  ANIMACAO
  DOCUMENTARIO
  OUTRO
}

model Filme {
  id                 Int       @id @default(autoincrement())
  titulo             String
  sinopse            String?
  classificacao      String?
  duracao            DateTime // Date solicitado
  elenco             String?
  genero             Genero?
  dataInicioExibicao DateTime? // Date solicitado
  dataFinalExibicao  DateTime? // Date solicitado

  sessoes Sessao[]

  // Relacionamento com Cinema
  cinema   Cinema @relation(fields: [cinemaId], references: [id])
  cinemaId Int
}

model Sala {
  id         Int   @id @default(autoincrement())
  numero     Int
  capacidade Int
  poltronas  Json? // Representa int[][]

  sessoes Sessao[]

  // Relacionamento com Cinema
  cinema   Cinema @relation(fields: [cinemaId], references: [id])
  cinemaId Int
}

model Sessao {
  id              Int      @id @default(autoincrement())
  horarioExibicao DateTime

  filme   Filme @relation(fields: [filmeId], references: [id])
  filmeId Int

  sala   Sala @relation(fields: [salaId], references: [id])
  salaId Int

  cinema   Cinema @relation(fields: [cinemaId], references: [id])
  cinemaId Int

  ingressos Ingresso[]
}

// VENDAS E CARRINHO
model Ingresso {
  id           Int   @id @default(autoincrement())
  valorInteira Float
  valorMeia    Float

  sessao   Sessao @relation(fields: [sessaoId], references: [id])
  sessaoId Int

  pedido   Pedido? @relation(fields: [pedidoId], references: [id])
  pedidoId Int?
}

model LancheCombo {
  id            Int     @id @default(autoincrement())
  nome          String
  descricao     String?
  valorUnitario Float
  quantidade    Int
  subtotal      Float

  pedido   Pedido? @relation(fields: [pedidoId], references: [id])
  pedidoId Int?
}

model Pedido {
  id         Int   @id @default(autoincrement())
  qtInteira  Int   @default(0)
  qtMeia     Int   @default(0)
  valorTotal Float

  ingresso Ingresso[]
  lanche   LancheCombo[]
}
